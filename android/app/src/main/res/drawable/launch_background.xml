<?xml version="1.0" encoding="utf-8"?>
<!-- Native launch splash: brand violet gradient with the centred logo mark.
     Shown while the Flutter engine starts, then handed off to the animated
     Lottie splash screen for a seamless brand reveal. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="#6C4DF6"
                android:endColor="#9B51E0" />
        </shape>
    </item>
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
